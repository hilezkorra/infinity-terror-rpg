  "_power_note": "Result = (die + modifier) * rank_power. This is what lets difficulty scale to 100/1000. A character/enemy's power comes from their rank. At a wide enough power gap, the strong side's worst roll beats the weak side's best roll.",
  "rank_power": {
    "unranked": 1,
    "f": 2,
    "e": 4,
    "d": 8,
    "c": 16,
    "b": 32,
    "a": 64,
    "s": 128,
    "ss": 256,
    "sss": 512
  },
  "dice": {
    "die_size": 20,
    "modifier_mode": "dnd",
    "_modifier_mode_note": "'dnd' = floor((stat-10)/2) keeps the d20 meaningful. 'flat' = add whole stat (randomness fades).",
    "crit_success_multiplier": 1.5,
    "crit_fail_multiplier": 0.5,
    "borderline_luck_gain": 1,
    "fail_by_one_luck_loss": 1,
